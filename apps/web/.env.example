# ─── Elite Suraksha — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# The app works WITHOUT any keys — it uses realistic mock data as fallback.

# OpenWeatherMap API Key (Free tier — 1000 calls/day)
# Get yours at: https://openweathermap.org/api
# Without this key, the app uses simulated weather data.
VITE_WEATHER_API_KEY=

# App config (optional)
VITE_APP_NAME=Elite Suraksha
VITE_APP_VERSION=1.0.0
